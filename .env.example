# Audio Intelligence — environment template.
#
# Copy this file to `.env` (which is git-ignored and NEVER committed) and fill in
# the real value. The app reads these at runtime via python-dotenv; the key is
# never logged or printed.

# REQUIRED — your Deepgram API key. Get one at https://console.deepgram.com/
DEEPGRAM_API_KEY=

# OPTIONAL — transcription language.
#   "multi" (default if unset) = Nova-3 multilingual auto code-switching.
#   "it"    = monolingual Italian; recommended for this all-Italian corpus
#             (a single tight language model beats hedging across many).
DEEPGRAM_LANGUAGE=it
